# FunnelHQ frontend — env template. Copy to `.env.local` for local dev,
# or set each value in your hosting platform (Vercel/Netlify/etc.) for prod.
# `.env*` files except this one are gitignored — never commit real values.

# ---------- Required (production build aborts if missing) ----------
VITE_API_BASE_URL=http://localhost:8082
VITE_FRONTEND_BASE_URL=http://localhost:8080

# Control Tower (admin) URL
VITE_CONTROL_TOWER_URL=http://localhost:8084

# ---------- Interview / live session ----------
VITE_LLM_BACKEND_URL=http://localhost:8082/api/interview-prelims-agent
VITE_STT_WEBSOCKET_URL=

VITE_INTERVIEW_TIMEOUT=1800000          # 30 min in ms
VITE_MAX_INTERVIEW_DURATION=1800        # 30 min in s
VITE_AUDIO_SAMPLE_RATE=16000
VITE_VIDEO_ENABLED=true
VITE_AUDIO_CALIBRATION_TIMEOUT=10000    # 10 s

# ---------- 3rd-party APIs ----------
VITE_CARTESIA_API_KEY=
VITE_GOOGLE_PLACES_API_KEY=

# ---------- Dev / debug ----------
VITE_DEBUG_INTERVIEW=false
VITE_MOCK_AI_RESPONSES=false

# ---------- Optional: error tracking ----------
# Leave blank to disable Sentry capture in the browser.
VITE_SENTRY_DSN=
